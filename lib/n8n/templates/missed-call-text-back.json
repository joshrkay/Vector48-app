        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ type: 'SMS', message: $json.sms_to_caller, contactId: $json.contact_id, locationId: $node['Extract Credential Fields'].json.locationId }) }}"
      },
