# Local dev: copy this file to .env.local and fill in real values.
# Do NOT use https://fake.supabase.co — it does not exist; sign-in will fail with "Failed to fetch".
# (Playwright E2E injects that placeholder only for automated smoke tests.)
#
# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
# paste as single line; no trailing newline/spaces
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# GoHighLevel — OAuth Marketplace App
# Marketplace App configured at: https://marketplace.gohighlevel.com
# API Base: https://services.leadconnectorhq.com
# OAuth consent: https://marketplace.gohighlevel.com/oauth/chooselocation
# Token endpoint: https://services.leadconnectorhq.com/oauth/token
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_OAUTH_REDIRECT_URI=https://app.vector48.ai/api/integrations/ghl/callback

# Legacy — Private Integration Token (deprecated; kept as fallback for existing accounts)
# GHL_AGENCY_API_KEY=
# GHL_AGENCY_ID=
# GHL_AGENCY_COMPANY_ID=

# 32-byte key, base64-encoded — used to encrypt/decrypt per-location GHL tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GHL_TOKEN_ENCRYPTION_KEY=
# Webhook verification token — set during GHL webhook registration
GHL_WEBHOOK_SECRET=
VECTOR40_BASE_URL=

# AI / Voice (Claude Sonnet — Estimate Audit recipe)
ELEVENLABS_API_KEY=
# Default ElevenLabs voice id for N8N AI Phone Answering provisioning (override per account in config if needed)
ELEVENLABS_DEFAULT_VOICE_ID=
ANTHROPIC_API_KEY=

# n8n — instance root (no trailing slash), e.g. https://YOUR_INSTANCE.app.n8n.cloud
N8N_API_KEY=
N8N_BASE_URL=
# n8n webhook base URL for recipe triggers (e.g. https://n8n.vector48.ai/webhook)
N8N_WEBHOOK_BASE_URL=

# Browser dev page /dev/n8n-test + /api/dev/n8n/ping (default on in next dev).
# For staging: set both so the sidebar shows the link.
ENABLE_N8N_DEV_TOOLS=
NEXT_PUBLIC_ENABLE_N8N_DEV_TOOLS=

# Cron (repair-n8n-provisioning): Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Recipe execution endpoints (/api/recipes/execution/*) — called by N8N workflows.
# N8N receives a per-account HMAC token at provisioning time derived from this secret:
#   token = HMAC-SHA256(RECIPE_EXECUTION_SECRET, accountId)
# Cross-tenant calls are cryptographically rejected. Rotate to invalidate all tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RECIPE_EXECUTION_SECRET=

# Upstash Redis — shared-state backend for the GHL per-location rate limiter.
# Optional in dev (falls back to an in-process counter); required for prod so
# the limit is enforced across serverless instances.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Playwright E2E — optional; when set, auth.setup persists session for authenticated.spec.ts
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=
#
# Run E2E against a deployed URL (staging/production) — no local dev server:
#   PLAYWRIGHT_BASE_URL=https://your-app.vercel.app npm run test:e2e:live
# Prefer staging/preview over production; use a dedicated test account (E2E_TEST_*).

# Settings / OAuth / encrypted credentials (32-byte key, base64 — same as GHL_TOKEN_ENCRYPTION_KEY format)
# ENCRYPTION_KEY=

# Google OAuth (Business Profile integration)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Jobber OAuth (developer app redirect URIs must match /api/integrations/jobber/callback)
# JOBBER_CLIENT_ID=
# JOBBER_CLIENT_SECRET=
