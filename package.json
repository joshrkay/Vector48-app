{
  "name": "vector48-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "type-check": "tsc --noEmit",
    "test:unit": "node --experimental-strip-types --test lib/cron/recipeTriggerDelivery.test.ts lib/recipes/webhookEvents.test.ts lib/recipes/contactRecipeActivity.test.ts lib/crm/inboxFilters.test.ts lib/crm/smsSegments.test.ts lib/recipes/runner/pricing.test.ts lib/recipes/runner/spendCap.test.ts",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
    "test:e2e:list": "playwright test --config=playwright.config.ts --list",
    "test:e2e:live": "node -e \"if (!process.env.PLAYWRIGHT_BASE_URL?.trim()) { console.error('Set PLAYWRIGHT_BASE_URL to your deployed URL, e.g. https://app.example.com'); process.exit(1); }\" && playwright test --config=playwright.config.ts",
    "create-test-account": "node scripts/create-test-account.mjs",
    "supabase": "npx --yes supabase@latest",
    "db:link": "npx --yes supabase@latest link",
    "db:push": "npx --yes supabase@latest db push",
    "verify:supabase-env": "node scripts/verify-supabase-env.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@hookform/resolvers": "3.9.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@stripe/stripe-js": "5.5.0",
    "@supabase/ssr": "0.6.1",
    "@supabase/supabase-js": "2.49.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "^11.18.0",
    "inngest": "3.31.0",
    "lucide-react": "0.474.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "7.54.2",
    "recharts": "2.15.1",
    "sonner": "^2.0.7",
    "stripe": "17.7.0",
    "tailwind-merge": "3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "3.24.2",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "22.13.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.14",
    "msw": "^2.12.14",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vitest": "^2.1.9"
  }
}
