            {
              "name": "Version",
              "value": "2021-07-28"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ type: 'SMS', message: 'Missed call: auto text-back sent to contact ' + $node['Merge Recipe Context'].json.contact_id + ($node['Merge Recipe Context'].json.call_id ? ' (call ' + $node['Merge Recipe Context'].json.call_id + ')' : '') + '.', contactId: $node['Extract SMS Text'].json.owner_contact_id, locationId: $node['Extract Credential Fields'].json.locationId }) }}"
      },
      "id": "14",
      "name": "SMS Owner",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3100,
        240
      ]
    },
    {
      "parameters": {
        "url": "={{$env.NEXT_PUBLIC_SUPABASE_URL}}/rest/v1/event_log",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
