# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# GoHighLevel — Private Integration Token
# Create at: GHL Settings > Private Integrations > Create New Integration
# API Base: https://services.leadconnectorhq.com
# MCP Endpoint: https://services.leadconnectorhq.com/mcp/
# Scopes needed: contacts, conversations, opportunities, calendars, locations, workflows
GHL_AGENCY_API_KEY=
GHL_AGENCY_ID=
# Company ID for sub-account creation (found in GHL admin under Agency Settings)
GHL_AGENCY_COMPANY_ID=
# 32-byte key, base64-encoded — used to encrypt/decrypt per-location GHL tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GHL_TOKEN_ENCRYPTION_KEY=
# Webhook verification token — set during GHL webhook registration
GHL_WEBHOOK_SECRET=

# AI / Voice (Claude Sonnet — Estimate Audit recipe)
ELEVENLABS_API_KEY=
# Default ElevenLabs voice id for N8N AI Phone Answering provisioning (override per account in config if needed)
ELEVENLABS_DEFAULT_VOICE_ID=
ANTHROPIC_API_KEY=

# n8n — base URL must include /api/v1 (no trailing slash), e.g. https://YOUR_INSTANCE.app.n8n.cloud/api/v1
N8N_API_KEY=
N8N_BASE_URL=
# n8n webhook base URL for recipe triggers (e.g. https://n8n.vector48.ai/webhook)
N8N_WEBHOOK_BASE_URL=

# Cron (repair-n8n-provisioning): Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Settings / OAuth / encrypted credentials (32-byte key, base64 — same as GHL_TOKEN_ENCRYPTION_KEY format)
# ENCRYPTION_KEY=

# Google OAuth (Business Profile integration)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Jobber OAuth (developer app redirect URIs must match /api/integrations/jobber/callback)
# JOBBER_CLIENT_ID=
# JOBBER_CLIENT_SECRET=
