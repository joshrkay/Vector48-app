            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ account_id: $node['Merge Recipe Context'].json.account_id, recipe_slug: 'missed-call-text-back', event_type: 'missed_call_text_back_sent', summary: 'Missed-call text-back SMS sent to caller', detail: { contact_id: $node['Merge Recipe Context'].json.contact_id, call_id: $node['Merge Recipe Context'].json.call_id, owner_notified: Boolean($node['Extract SMS Text'].json.owner_contact_id), textBackDelaySec: $node['Extract SMS Text'].json.textBackDelaySec } }) }}"
      },
      "id": "15",
      "name": "Write event_log",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3320,
        360
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"ok\": true, \"recipe\": \"missed-call-text-back\"}"
      },
